{
  "packageManager": "pnpm@8.14.0",
  "description": "MAXHUB - Full-stack application with Vue 3 component library",
  "license": "MIT",
  "private": true,
  "homepage": "http://www.layui-vue.com",
  "workspaces": [
    "packages/*",
    "app",
    "docs/site"
  ],
  "scripts": {
    "dev": "pnpm -C app dev",
    "dev:play": "pnpm -C play dev",
    "dev:docs": "pnpm -C docs/site dev",
    "test": "vitest run",
    "build": "pnpm --workspace-concurrency=1 run \"/^build:.*/\"",
    "build:app": "pnpm -C app build",
    "build:icons": "pnpm -C packages/icons build",
    "build:layer": "pnpm -C packages/layer build",
    "build:component": "pnpm -C packages/layui build",
    "build:form": "pnpm -C packages/json-schema-form build",
    "build:docs": "pnpm -C docs/site build",
    "publish:component": "pnpm -C packages/layui publish",
    "generate:icons": "pnpm -C packages/icons generate",
    "lint": "eslint --fix",
    "commit:eslint": "node ./build/commit-eslint.js",
    "postinstall": "pnpm run build",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "@vue/runtime-core": "3.3.13",
    "vue": "3.3.13"
  },
  "dependencies": {
    "@layui/component": "workspace:*",
    "@layui/icons-vue": "workspace:*",
    "@layui/json-schema-form": "workspace:*",
    "@layui/layer-vue": "workspace:*",
    "@layui/layui-vue": "workspace:*",
    "vue": "3.3.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.11.0",
    "@babel/core": "^7.17.9",
    "@babel/preset-env": "^7.15.8",
    "@babel/preset-typescript": "^7.15.0",
    "@commitlint/cli": "^16.2.1",
    "@commitlint/config-conventional": "^16.2.1",
    "@microsoft/api-extractor": "^7.34.4",
    "@rollup/plugin-babel": "^6.0.4",
    "@types/node": "^18.11.9",
    "@types/uuid": "^8.3.4",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/test-utils": "2.4.5",
    "commitizen": "^4.2.4",
    "commitlint-config-cz": "^0.13.3",
    "components-helper": "2.1.3",
    "consola": "^3.4.2",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^6.3.0",
    "eslint": "^9.23.0",
    "eslint-plugin-format": "^1.0.1",
    "execa": "^6.1.0",
    "happy-dom": "9.8.2",
    "husky": "^8.0.1",
    "less": "^4.1.3",
    "rimraf": "^3.0.2",
    "rollup": "^4.9.4",
    "tsx": "^4.12.0",
    "typescript": "^4.9.5",
    "vite": "5.0.11",
    "vitest": "1.4.0",
    "vue-component-meta": "^1.0.8",
    "vue-tsc": "1.5.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "config/.cz-config.js"
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  }
}

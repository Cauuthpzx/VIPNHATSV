generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  ADMIN
  MANAGER
  VIEWER
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  type        RoleType @default(VIEWER)
  level       Int      @default(0)
  permissions String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("roles")
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  email          String?
  password       String
  name           String
  fundPassword   String?        @map("fund_password")
  isActive       Boolean        @default(true) @map("is_active")
  tokenVersion   Int            @default(0) @map("token_version")
  lastLoginAt    DateTime?      @map("last_login_at")
  lastLoginIp    String?        @map("last_login_ip")
  roleId         String         @map("role_id")
  role           Role           @relation(fields: [roleId], references: [id])
  refreshTokens    RefreshToken[]
  dashboardSetting DashboardSetting?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@index([createdAt(sort: Desc)])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Agent {
  id            String    @id @default(cuid())
  name          String
  extUsername   String    @unique @map("ext_username")
  extPassword   String    @default("") @map("ext_password")
  baseUrl       String?   @map("base_url")
  sessionCookie String    @map("session_cookie")
  cookieExpires DateTime? @map("cookie_expires")
  status        String    @default("active")
  isActive      Boolean   @default(true) @map("is_active")
  loginError    String?   @map("login_error")
  loginAttempts Int       @default(0) @map("login_attempts")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  loginHistory  AgentLoginHistory[]
  notifications Notification[]

  @@map("agents")
}

model AgentLoginHistory {
  id              String   @id @default(cuid())
  agentId         String   @map("agent_id")
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  success         Boolean
  captchaAttempts Int      @default(0) @map("captcha_attempts")
  errorMessage    String?  @map("error_message")
  ipAddress       String?  @map("ip_address")
  triggeredBy     String   @default("manual") @map("triggered_by")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([agentId, createdAt(sort: Desc)])
  @@map("agent_login_history")
}

// ===================================================================
// NOTIFICATIONS — member change detection during sync
// ===================================================================

model Notification {
  id        String   @id @default(cuid())
  agentId   String   @map("agent_id")
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type      String   // "member_new" | "member_lost" | "big_deposit" | "big_withdrawal"
  username  String
  money     String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([isRead, createdAt(sort: Desc)])
  @@index([agentId])
  @@index([agentId, username, createdAt])
  @@index([type, createdAt(sort: Desc)])
  @@map("notifications")
}

// ===================================================================
// DASHBOARD SETTINGS — per-user polling interval & chart preferences
// ===================================================================

model DashboardSetting {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Polling interval in seconds (0 = disabled)
  pollInterval   Int      @default(60) @map("poll_interval")
  /// Notification threshold for big deposit (VND)
  bigDepositMin  Decimal  @default(10000000) @db.Decimal(18, 4) @map("big_deposit_min")
  /// Notification threshold for big withdrawal (VND)
  bigWithdrawMin Decimal  @default(10000000) @db.Decimal(18, 4) @map("big_withdraw_min")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("dashboard_settings")
}

// ===================================================================
// PROXY DATA TABLES — synced from upstream via background job
// ===================================================================

model ProxyUser {
  id               String   @id @default(cuid())
  agentId          String   @map("agent_id")
  username         String
  typeFormat       String?  @map("type_format")
  parentUser       String?  @map("parent_user")
  money            Decimal? @db.Decimal(18, 4)
  depositCount     Int?     @default(0) @map("deposit_count")
  withdrawalCount  Int?     @default(0) @map("withdrawal_count")
  depositAmount    Decimal? @default(0) @db.Decimal(18, 4) @map("deposit_amount")
  withdrawalAmount Decimal? @default(0) @db.Decimal(18, 4) @map("withdrawal_amount")
  loginTime        String?  @map("login_time")
  registerTime     String?  @map("register_time")
  statusFormat     String?  @map("status_format")
  raw              Json     @default("{}")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@unique([agentId, username], name: "uq_proxy_user")
  @@index([agentId])
  @@index([registerTime(sort: Desc)])
  @@index([agentId, registerTime(sort: Desc)])
  @@index([agentId, money(sort: Desc)])
  @@index([agentId, depositAmount(sort: Desc)])
  @@map("proxy_users")
}

model ProxyInvite {
  id               String   @id @default(cuid())
  agentId          String   @map("agent_id")
  inviteCode       String   @map("invite_code")
  userType         String?  @map("user_type")
  regCount         Int?     @default(0) @map("reg_count")
  scopeRegCount    Int?     @default(0) @map("scope_reg_count")
  rechargeCount    Int?     @default(0) @map("recharge_count")
  firstRechargeCount Int?   @default(0) @map("first_recharge_count")
  registerRechargeCount Int? @default(0) @map("register_recharge_count")
  remark           String?
  createTime       String?  @map("create_time")
  raw              Json     @default("{}")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@unique([agentId, inviteCode], name: "uq_invite")
  @@index([agentId])
  @@index([createTime(sort: Desc)])
  @@map("proxy_invites")
}

model ProxyDeposit {
  id               String   @id @default(cuid())
  agentId          String   @map("agent_id")
  username         String
  userParentFormat String?  @map("user_parent_format")
  amount           Decimal? @db.Decimal(18, 4)
  type             String?
  status           String?
  createTime       String?  @map("create_time")
  syncDate         String?  @map("sync_date") /// Ngày dữ liệu thuộc về (YYYY-MM-DD), dùng để query/filter theo ngày
  raw              Json     @default("{}")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@unique([agentId, username, amount, type, createTime], name: "uq_deposit")
  @@index([agentId])
  @@index([agentId, syncDate])
  @@index([createTime(sort: Desc)])
  @@index([username, createTime(sort: Desc)])
  @@index([syncDate])
  @@map("proxy_deposits")
}

model ProxyWithdrawal {
  id               String   @id @default(cuid())
  agentId          String   @map("agent_id")
  serialNo         String   @unique @map("serial_no")
  username         String
  userParentFormat String?  @map("user_parent_format")
  amount           Decimal? @db.Decimal(18, 4)
  userFee          Decimal? @db.Decimal(18, 4) @map("user_fee")
  trueAmount       Decimal? @db.Decimal(18, 4) @map("true_amount")
  statusFormat     String?  @map("status_format")
  createTime       String?  @map("create_time")
  syncDate         String?  @map("sync_date") /// Ngày dữ liệu thuộc về (YYYY-MM-DD)
  raw              Json     @default("{}")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@index([agentId])
  @@index([agentId, syncDate])
  @@index([createTime(sort: Desc)])
  @@index([username, createTime(sort: Desc)])
  @@index([syncDate])
  @@map("proxy_withdrawals")
}

model ProxyBet {
  id             String   @id @default(cuid())
  agentId        String   @map("agent_id")
  serialNo       String   @unique @map("serial_no")
  username       String
  lotteryName    String?  @map("lottery_name")
  playTypeName   String?  @map("play_type_name")
  playName       String?  @map("play_name")
  issue          String?
  content        String?
  money          Decimal? @db.Decimal(18, 4)
  rebateAmount   Decimal? @db.Decimal(18, 4) @map("rebate_amount")
  result         Decimal? @db.Decimal(18, 4)
  statusText     String?  @map("status_text")
  createTime     String?  @map("create_time")
  syncDate       String?  @map("sync_date") /// Ngày dữ liệu thuộc về (YYYY-MM-DD)
  raw            Json     @default("{}")
  syncedAt       DateTime @default(now()) @map("synced_at")

  @@index([agentId])
  @@index([agentId, syncDate])
  @@index([createTime(sort: Desc)])
  @@index([username, createTime(sort: Desc)])
  @@index([syncDate])
  @@map("proxy_bets")
}

model ProxyBetOrder {
  id               String   @id @default(cuid())
  agentId          String   @map("agent_id")
  serialNo         String   @unique @map("serial_no")
  platformIdName   String?  @map("platform_id_name")
  platformUsername  String?  @map("platform_username")
  cName            String?  @map("c_name")
  gameName         String?  @map("game_name")
  betAmount        Decimal? @db.Decimal(18, 4) @map("bet_amount")
  turnover         Decimal? @db.Decimal(18, 4)
  prize            Decimal? @db.Decimal(18, 4)
  winLose          Decimal? @db.Decimal(18, 4) @map("win_lose")
  betTime          String?  @map("bet_time")
  syncDate         String?  @map("sync_date") /// Ngày dữ liệu thuộc về (YYYY-MM-DD)
  raw              Json     @default("{}")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@index([agentId])
  @@index([agentId, syncDate])
  @@index([betTime(sort: Desc)])
  @@index([platformUsername, betTime(sort: Desc)])
  @@index([syncDate])
  @@map("proxy_bet_orders")
}

model ProxyReportLottery {
  id               String   @id @default(cuid())
  agentId          String   @map("agent_id")
  username         String
  userParentFormat String?  @map("user_parent_format")
  lotteryName      String   @map("lottery_name")
  betCount         Int?     @default(0) @map("bet_count")
  betAmount        Decimal? @db.Decimal(18, 4) @map("bet_amount")
  validAmount      Decimal? @db.Decimal(18, 4) @map("valid_amount")
  rebateAmount     Decimal? @db.Decimal(18, 4) @map("rebate_amount")
  result           Decimal? @db.Decimal(18, 4)
  winLose          Decimal? @db.Decimal(18, 4) @map("win_lose")
  prize            Decimal? @db.Decimal(18, 4)
  reportDate       String   @map("report_date")
  raw              Json     @default("{}")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@unique([agentId, username, lotteryName, reportDate], name: "uq_report_lottery")
  @@index([agentId])
  @@index([agentId, reportDate])
  @@index([reportDate(sort: Desc)])
  @@index([username, reportDate(sort: Desc)])
  @@map("proxy_report_lottery")
}

model ProxyReportFunds {
  id                   String   @id @default(cuid())
  agentId              String   @map("agent_id")
  username             String
  userParentFormat     String?  @map("user_parent_format")
  depositCount         Int?     @default(0) @map("deposit_count")
  depositAmount        Decimal? @db.Decimal(18, 4) @map("deposit_amount")
  withdrawalCount      Int?     @default(0) @map("withdrawal_count")
  withdrawalAmount     Decimal? @db.Decimal(18, 4) @map("withdrawal_amount")
  chargeFee            Decimal? @db.Decimal(18, 4) @map("charge_fee")
  agentCommission      Decimal? @db.Decimal(18, 4) @map("agent_commission")
  promotion            Decimal? @db.Decimal(18, 4)
  thirdRebate          Decimal? @db.Decimal(18, 4) @map("third_rebate")
  thirdActivityAmount  Decimal? @db.Decimal(18, 4) @map("third_activity_amount")
  reportDate           String   @map("report_date")
  raw                  Json     @default("{}")
  syncedAt             DateTime @default(now()) @map("synced_at")

  @@unique([agentId, username, reportDate], name: "uq_report_funds")
  @@index([agentId])
  @@index([agentId, reportDate])
  @@index([reportDate(sort: Desc)])
  @@index([username, reportDate(sort: Desc)])
  @@map("proxy_report_funds")
}

model ProxyReportThirdGame {
  id               String   @id @default(cuid())
  agentId          String   @map("agent_id")
  username         String
  platformIdName   String   @map("platform_id_name")
  tBetTimes        Int?     @default(0) @map("t_bet_times")
  tBetAmount       Decimal? @db.Decimal(18, 4) @map("t_bet_amount")
  tTurnover        Decimal? @db.Decimal(18, 4) @map("t_turnover")
  tPrize           Decimal? @db.Decimal(18, 4) @map("t_prize")
  tWinLose         Decimal? @db.Decimal(18, 4) @map("t_win_lose")
  reportDate       String   @map("report_date")
  raw              Json     @default("{}")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@unique([agentId, username, platformIdName, reportDate], name: "uq_report_third_game")
  @@index([agentId])
  @@index([agentId, reportDate])
  @@index([reportDate(sort: Desc)])
  @@index([username, reportDate(sort: Desc)])
  @@map("proxy_report_third_game")
}

model ProxyBank {
  id           String   @id @default(cuid())
  agentId      String   @map("agent_id")
  upstreamId   String   @unique @map("upstream_id")
  isDefault    String?  @map("is_default_format")
  bankName     String?  @map("bank_name")
  bankBranch   String?  @map("bank_branch")
  cardNo       String?  @map("card_no")
  name         String?
  raw          Json     @default("{}")
  syncedAt     DateTime @default(now()) @map("synced_at")

  @@index([agentId])
  @@map("proxy_banks")
}

model SyncDateLock {
  id        String   @id @default(cuid())
  tableName String   @map("table_name")
  syncDate  String   @map("sync_date")
  agentId   String   @map("agent_id")
  itemCount Int      @default(0) @map("item_count")
  hash      String?  @map("hash")
  lockedAt  DateTime @default(now()) @map("locked_at")

  @@unique([tableName, syncDate, agentId], name: "uq_sync_date_lock")
  @@index([tableName])
  @@index([agentId])
  @@map("sync_date_locks")
}

// ===================================================================
// EMPLOYEE-CUSTOMER MAPPING — Revenue Report (Doanh Thu)
// ===================================================================

model Employee {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customers EmployeeCustomer[]

  @@map("employees")
}

model EmployeeCustomer {
  id               String   @id @default(cuid())
  employeeId       String   @map("employee_id")
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  customerUsername  String   @map("customer_username")
  assignedDate     String?  @map("assigned_date")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([employeeId, customerUsername], name: "uq_employee_customer")
  @@index([customerUsername])
  @@index([employeeId])
  @@map("employee_customers")
}

// ===================================================================
// OLD CUSTOMER — Khách hàng cũ trước khi tách đại lý
// ===================================================================

model OldCustomer {
  id               String   @id @default(cuid())
  assignedDate     String?  @map("assigned_date")       // Cột A: Ngày tháng (YYYY-MM-DD)
  employeeName     String   @map("employee_name")       // Cột B: Tên nhân viên
  agentCode        String?  @map("agent_code")          // Cột C: Dây đại lí
  username         String   @map("username")            // Cột D: Tên tài khoản
  contactInfo      String?  @map("contact_info")        // Cột E: Zalo/FB/Tele
  source           String?  @map("source")              // Cột F: Nguồn
  referralAccount  String?  @map("referral_account")    // Cột G: TK giới thiệu
  firstDeposit     Decimal? @map("first_deposit") @db.Decimal(18, 2) // Cột I: Nạp đầu
  onlineDays       Json?    @map("online_days")   @db.JsonB          // ["11-01","11-15",...] ngày online
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([username, employeeName], name: "uq_old_customer")
  @@index([username])
  @@index([employeeName])
  @@index([agentCode])
  @@map("old_customers")
}
